{
  "tasks": {
    "start": "deno task serve & deno task wallet-service",
    "serve": "deno run --allow-all --env-file=.env server.js",
    "build": "qjs --std build.js",
    "deploy": "./plan1.sh deploy",
    "compile:server": "deno desktop server.js",
    "compile:desktop": "deno desktop scripts/desktop-bridge.js --backend webview",
    "desktop": "./scripts/laufey --runtime ./server/server.so",
    "test": "deno test --no-check --allow-net --allow-env --env-file=.env debugging_utilities/test_was_e2e.ts",
    "test:hearts": "deno test --allow-read client/public/elves/hearts-engine.test.js",
    "test:sports": "deno test --allow-read client/public/elves/sports-engine.test.js",
    "test:sports-stats": "deno test --allow-read client/public/elves/sports-stats-engine.test.js",
    "wallet-service": "./scripts/wallet-service.sh",
    "9p": "deno run --allow-net --allow-read --allow-write --allow-env server/9p/main.ts"
  }
}
