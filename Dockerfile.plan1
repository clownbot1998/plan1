FROM denoland/deno:2.3.3

WORKDIR /app

COPY deno.json ./
COPY server.js ./
COPY storage.mjs ./

# cache all remote deps at build time so the container doesn't need outbound network at startup
RUN deno cache --no-lock server.js

# dist/ is bind-mounted at runtime in local dev (docker-compose.local.yml)

EXPOSE 1998

CMD ["deno", "run", "--no-lock", "--allow-read", "--allow-net", "--allow-env", "--allow-run", "--allow-write", "server.js"]
